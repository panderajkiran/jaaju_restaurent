# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Reservation request emails (src/lib/api/reservations.functions.ts).
# Without these, the reserve form still validates and logs server-side,
# but no email is sent.
RESEND_API_KEY=
RESERVATION_EMAIL_TO=
# Optional verified sender; defaults to Resend's onboarding@resend.dev (testing only)
RESERVATION_EMAIL_FROM=
